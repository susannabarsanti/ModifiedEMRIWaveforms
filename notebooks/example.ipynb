    "print(f\"Tobs  = {Tobs} yr\\n\")\n",
    "\n",
    "\n",
    "# Compute separatrix (innermost stable orbit) for these parameters\n",
    "p_sep = get_separatrix(a, e0, x_I0)\n",
    "print(f\"Separatrix (p_sep) = {p_sep}\\n\")\n",
    "\n",
    "emri_injection_params_GR = [\n",
